-- Население каждого региона
-- 
-- Посчитайте население каждого региона. В качестве результата выведите название региона и его численность населения.
-- Поля в результирующей таблице:
-- region_name
-- total_population

SELECT 
    DISTINCT Regions.name AS region_name,
    SUM(Cities.population) OVER (PARTITION BY Cities.regionid) AS total_population
FROM Regions
JOIN Cities ON Cities.regionid = Regions.id
